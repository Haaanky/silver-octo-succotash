@inject IAuthService AuthService
@inject NavigationManager Nav

<nav class="navbar navbar-expand-sm navbar-dark bg-dark px-3">
    <a class="navbar-brand" href="/">LagerApp</a>
    <button class="navbar-toggler" type="button" @onclick="ToggleNav">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse @(_navOpen ? "show" : "")">
        <ul class="navbar-nav me-auto">
            <li class="nav-item">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Lagerlista</NavLink>
            </li>
            <li class="nav-item">
                <NavLink class="nav-link" href="/scan">Scanna</NavLink>
            </li>
            @if (_currentUser?.IsAdmin == true)
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="/products">Produkter</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/history">Historik</NavLink>
                </li>
            }
            <li class="nav-item">
                <NavLink class="nav-link" href="/export">Export</NavLink>
            </li>
        </ul>
        @if (_currentUser is not null)
        {
            <span class="navbar-text me-3 text-light">@_currentUser.Email (@_currentUser.Role)</span>
            <button class="btn btn-outline-light btn-sm" @onclick="Logout">Logga ut</button>
        }
    </div>
</nav>

@code {
    private User? _currentUser;
    private bool _navOpen = false;

    protected override async Task OnInitializedAsync()
    {
        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private void ToggleNav() => _navOpen = !_navOpen;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
