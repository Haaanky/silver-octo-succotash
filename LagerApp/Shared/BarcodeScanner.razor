@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="scanner-container">
    @if (!_scanning && string.IsNullOrEmpty(_error))
    {
        <button class="btn btn-primary mb-2" @onclick="StartScanning">
            Starta kamera
        </button>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-warning">
            <strong>Kamera ej tillgänglig:</strong> @_error
        </div>
    }

    @if (_scanning)
    {
        <div class="video-wrapper">
            <video id="@_videoId" autoplay playsinline muted class="scanner-video"></video>
            <div class="scan-overlay">
                <div class="scan-frame"></div>
            </div>
        </div>
        <button class="btn btn-secondary mt-2 mb-2" @onclick="StopScanning">Stoppa kamera</button>
    }

    <div class="mt-2">
        <label class="form-label">@(_scanning ? "Eller ange manuellt:" : "Ange streckkod manuellt:")</label>
        <div class="input-group">
            <input type="text" class="form-control" @bind="_manualBarcode" @bind:event="oninput" @onkeydown="OnKeyDown" placeholder="Ange streckkod eller SKU" />
            <button class="btn btn-secondary" @onclick="SubmitManual">OK</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnScanned { get; set; }

    private string _videoId = $"scanner-video-{Guid.NewGuid():N}";
    private bool _scanning = false;
    private string _error = string.Empty;
    private string _manualBarcode = string.Empty;
    private IJSObjectReference? _scannerModule;
    private DotNetObjectReference<BarcodeScanner>? _dotnetRef;

    private async Task StartScanning()
    {
        _error = string.Empty;
        _scanning = true;
        StateHasChanged();

        await Task.Delay(100); // allow DOM to render video element

        _scannerModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/scanner.js");
        _dotnetRef ??= DotNetObjectReference.Create(this);

        var result = await _scannerModule.InvokeAsync<ScannerResult>("startScanner", _dotnetRef, _videoId);
        if (!result.Success)
        {
            _scanning = false;
            _error = result.Error ?? "Okänt fel vid kamerastart.";
        }
    }

    private async Task StopScanning()
    {
        _scanning = false;
        if (_scannerModule is not null)
            await _scannerModule.InvokeVoidAsync("stopScanner");
    }

    [JSInvokable]
    public async Task OnBarcodeDetected(string barcode)
    {
        await StopScanning();
        await OnScanned.InvokeAsync(barcode);
    }

    private async Task SubmitManual()
    {
        if (!string.IsNullOrWhiteSpace(_manualBarcode))
        {
            var value = _manualBarcode.Trim();
            _manualBarcode = string.Empty;
            await StopScanning();
            await OnScanned.InvokeAsync(value);
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SubmitManual();
    }

    public async ValueTask DisposeAsync()
    {
        if (_scanning)
            await StopScanning();
        _dotnetRef?.Dispose();
        if (_scannerModule is not null)
            await _scannerModule.DisposeAsync();
    }

    private class ScannerResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
    }
}
