@page "/"
@inject IProductService ProductService

<PageTitle>Lagerlista — LagerApp</PageTitle>

<h1>Lagerlista</h1>

<div class="mb-3">
    <input type="search" class="form-control" placeholder="Sök produkt, SKU eller streckkod…"
           @bind="_search" @bind:event="oninput" />
</div>

@if (_products is null)
{
    <p>Laddar…</p>
}
else if (!_filtered.Any())
{
    <p class="text-muted">Inga produkter hittades.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Produkt</th>
                    <th>SKU</th>
                    <th>Saldo</th>
                    <th>Enhet</th>
                    <th>Min.nivå</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _filtered)
                {
                    <tr class="@(p.IsLowStock ? "table-danger" : "")">
                        <td><strong>@p.Name</strong></td>
                        <td><code>@p.Sku</code></td>
                        <td>@p.CurrentStock</td>
                        <td>@p.Unit</td>
                        <td>@p.MinStock</td>
                        <td>
                            @if (p.IsLowStock)
                            {
                                <span class="badge bg-danger">Lågt saldo</span>
                            }
                            else
                            {
                                <span class="badge bg-success">OK</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Product>? _products;
    private string _search = string.Empty;

    private IEnumerable<Product> _filtered => _products?.Where(p =>
        string.IsNullOrWhiteSpace(_search) ||
        p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        p.Sku.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        p.Barcode.Contains(_search, StringComparison.OrdinalIgnoreCase)
    ) ?? Enumerable.Empty<Product>();

    protected override async Task OnInitializedAsync()
    {
        _products = await ProductService.GetAllAsync();
    }
}
