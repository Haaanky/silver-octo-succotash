@page "/export"
@inject ITransactionService TransactionService
@inject IProductService ProductService
@inject IExportService ExportService
@inject NavigationManager Nav

<PageTitle>Export — LagerApp</PageTitle>

<h1>Exportera data</h1>

<p class="text-muted">Ladda ned lagerdata som CSV- eller JSON-fil, eller skicka via e-post.</p>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}

<div class="d-flex flex-wrap gap-2 mb-4">
    <button class="btn btn-primary" @onclick="DownloadCsv" disabled="@_loading">
        Ladda ned CSV
    </button>
    <button class="btn btn-secondary" @onclick="DownloadJson" disabled="@_loading">
        Ladda ned JSON
    </button>
    <button class="btn btn-outline-primary" @onclick="SendEmail" disabled="@_loading">
        Ladda ned CSV &amp; öppna e-post
    </button>
</div>

@if (_showMailtoInfo)
{
    <div class="alert alert-info">
        <strong>CSV-filen har laddats ned.</strong> Bifoga den i det e-postmeddelande som öppnas i din e-postklient.
    </div>
}

@code {
    private bool _loading = false;
    private string _message = string.Empty;
    private bool _showMailtoInfo = false;

    private async Task<(List<StockTransaction> txs, List<Product> prods)> LoadDataAsync()
    {
        var txs = await TransactionService.GetAllAsync();
        var prods = await ProductService.GetAllAsync();
        return (txs, prods);
    }

    private async Task DownloadCsv()
    {
        _loading = true;
        _message = string.Empty;
        var (txs, prods) = await LoadDataAsync();
        var csv = ExportService.GenerateCsv(txs, prods);
        await ExportService.DownloadFileAsync($"lagerexport_{DateTime.Now:yyyyMMdd}.csv", csv, "text/csv;charset=utf-8;");
        _message = "CSV-fil nedladdad.";
        _loading = false;
    }

    private async Task DownloadJson()
    {
        _loading = true;
        _message = string.Empty;
        var (txs, prods) = await LoadDataAsync();
        var json = ExportService.GenerateJson(txs, prods);
        await ExportService.DownloadFileAsync($"lagerexport_{DateTime.Now:yyyyMMdd}.json", json, "application/json;charset=utf-8;");
        _message = "JSON-fil nedladdad.";
        _loading = false;
    }

    private async Task SendEmail()
    {
        _loading = true;
        _showMailtoInfo = false;
        _message = string.Empty;

        var (txs, prods) = await LoadDataAsync();
        var csv = ExportService.GenerateCsv(txs, prods);
        var filename = $"lagerexport_{DateTime.Now:yyyyMMdd}.csv";

        await ExportService.DownloadFileAsync(filename, csv, "text/csv;charset=utf-8;");
        _showMailtoInfo = true;

        Nav.NavigateTo($"mailto:?subject=Lagerexport {DateTime.Now:yyyy-MM-dd}&body={Uri.EscapeDataString($"Hej,\n\nBifogat finns lagerdatan som CSV ({filename}).\n")}");
        _loading = false;
    }
}
