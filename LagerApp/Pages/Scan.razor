@page "/scan"
@inject IProductService ProductService
@inject ITransactionService TransactionService
@inject IAuthService AuthService

<PageTitle>Scanna — LagerApp</PageTitle>

<h1>Registrera rörelse</h1>

@if (_step == Step.Scan)
{
    <p class="text-muted">Scanna en streckkod eller ange manuellt.</p>
    <BarcodeScanner OnScanned="OnScanned" />
}

@if (_step == Step.Confirm)
{
    @if (_product is null)
    {
        <div class="alert alert-warning">
            <strong>Produkt hittades inte</strong> för streckkod: <code>@_scannedValue</code>
        </div>
        <button class="btn btn-secondary" @onclick="Reset">Försök igen</button>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5>@_product.Name</h5>
                <p class="mb-1">SKU: <code>@_product.Sku</code></p>
                <p class="mb-1">Aktuellt saldo: <strong>@_product.CurrentStock @_product.Unit</strong></p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        <div class="row g-3 align-items-end">
            <div class="col-sm-4">
                <label class="form-label">Typ</label>
                <select class="form-select" @bind="_transactionType">
                    <option value="in">Inleverans (+)</option>
                    <option value="out">Utleverans (-)</option>
                </select>
            </div>
            <div class="col-sm-4">
                <label class="form-label">Antal</label>
                <input type="number" class="form-control" min="1" @bind="_quantity" />
            </div>
            <div class="col-sm-4">
                <button class="btn btn-primary w-100" @onclick="Register" disabled="@_loading">
                    @(_loading ? "Sparar…" : "Registrera")
                </button>
            </div>
        </div>
        <button class="btn btn-link mt-2" @onclick="Reset">Scanna igen</button>
    }
}

@if (_step == Step.Done)
{
    <div class="alert alert-success">
        <strong>Klart!</strong> @_doneMessage
    </div>
    <button class="btn btn-primary" @onclick="Reset">Registrera fler</button>
}

@code {
    private enum Step { Scan, Confirm, Done }
    private Step _step = Step.Scan;
    private string _scannedValue = string.Empty;
    private Product? _product;
    private string _transactionType = "in";
    private int _quantity = 1;
    private bool _loading = false;
    private string _error = string.Empty;
    private string _doneMessage = string.Empty;

    private async Task OnScanned(string value)
    {
        _scannedValue = value;
        _product = await ProductService.GetByBarcodeAsync(value);
        _step = Step.Confirm;
    }

    private async Task Register()
    {
        if (_quantity <= 0)
        {
            _error = "Antal måste vara minst 1.";
            return;
        }
        if (_product is null) return;

        _loading = true;
        _error = string.Empty;

        var user = await AuthService.GetCurrentUserAsync();
        await TransactionService.RegisterAsync(_product.Id, _transactionType, _quantity, user?.Id ?? "");

        var updated = await ProductService.GetByIdAsync(_product.Id);
        var typeText = _transactionType == "in" ? "inleverans" : "utleverans";
        _doneMessage = $"{typeText} på {_quantity} {_product.Unit} registrerad för {_product.Name}. Nytt saldo: {updated?.CurrentStock} {_product.Unit}.";
        _loading = false;
        _step = Step.Done;
    }

    private void Reset()
    {
        _step = Step.Scan;
        _scannedValue = string.Empty;
        _product = null;
        _quantity = 1;
        _error = string.Empty;
        _doneMessage = string.Empty;
    }
}
