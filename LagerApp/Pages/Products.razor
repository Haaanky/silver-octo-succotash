@page "/products"
@inject IProductService ProductService
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Produkthantering — LagerApp</PageTitle>

<h1>Produkter</h1>

@if (!_isAdmin)
{
    <div class="alert alert-danger">Åtkomst nekad. Endast admins kan hantera produkter.</div>
    return;
}

<button class="btn btn-success mb-3" @onclick="NewProduct">+ Ny produkt</button>

@if (_editing is not null)
{
    <div class="card mb-4">
        <div class="card-header">@(_isNew ? "Skapa produkt" : "Redigera produkt")</div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(_formError))
            {
                <div class="alert alert-danger">@_formError</div>
            }
            <div class="row g-3">
                <div class="col-sm-6">
                    <label class="form-label">Namn</label>
                    <input class="form-control" @bind="_editing.Name" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label">SKU</label>
                    <input class="form-control" @bind="_editing.Sku" />
                </div>
                <div class="col-sm-6">
                    <label class="form-label">Streckkod</label>
                    <input class="form-control" @bind="_editing.Barcode" />
                </div>
                <div class="col-sm-3">
                    <label class="form-label">Enhet</label>
                    <input class="form-control" @bind="_editing.Unit" />
                </div>
                <div class="col-sm-3">
                    <label class="form-label">Miniminivå</label>
                    <input type="number" class="form-control" @bind="_editing.MinStock" min="0" />
                </div>
                @if (_isNew)
                {
                    <div class="col-sm-3">
                        <label class="form-label">Startsaldo</label>
                        <input type="number" class="form-control" @bind="_editing.CurrentStock" min="0" />
                    </div>
                }
            </div>
            <div class="mt-3">
                <button class="btn btn-primary me-2" @onclick="SaveProduct">Spara</button>
                <button class="btn btn-secondary" @onclick="CancelEdit">Avbryt</button>
            </div>
        </div>
    </div>
}

@if (_products is null)
{
    <p>Laddar…</p>
}
else if (!_products.Any())
{
    <p class="text-muted">Inga produkter ännu.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Namn</th>
                    <th>SKU</th>
                    <th>Streckkod</th>
                    <th>Saldo</th>
                    <th>Min.nivå</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _products)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td><code>@p.Sku</code></td>
                        <td><code>@p.Barcode</code></td>
                        <td>@p.CurrentStock @p.Unit</td>
                        <td>@p.MinStock</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditProduct(p)">Redigera</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(p.Id)">Ta bort</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Product>? _products;
    private Product? _editing;
    private bool _isNew = false;
    private bool _isAdmin = false;
    private string _formError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        _isAdmin = user?.IsAdmin == true;
        if (_isAdmin)
            _products = await ProductService.GetAllAsync();
    }

    private void NewProduct()
    {
        _editing = new Product();
        _isNew = true;
        _formError = string.Empty;
    }

    private void EditProduct(Product p)
    {
        _editing = new Product
        {
            Id = p.Id, Name = p.Name, Sku = p.Sku,
            Barcode = p.Barcode, Unit = p.Unit,
            MinStock = p.MinStock, CurrentStock = p.CurrentStock
        };
        _isNew = false;
        _formError = string.Empty;
    }

    private async Task SaveProduct()
    {
        if (_editing is null) return;
        if (string.IsNullOrWhiteSpace(_editing.Name))
        {
            _formError = "Namn krävs.";
            return;
        }
        await ProductService.SaveAsync(_editing);
        _products = await ProductService.GetAllAsync();
        _editing = null;
    }

    private async Task DeleteProduct(string id)
    {
        await ProductService.DeleteAsync(id);
        _products = await ProductService.GetAllAsync();
    }

    private void CancelEdit() => _editing = null;
}
